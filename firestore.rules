rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ─────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function getRole(babyId) {
      return get(/databases/$(database)/documents/babies/$(babyId)).data.members[request.auth.uid];
    }

    function isMember(babyId) {
      return isSignedIn() &&
             request.auth.uid in get(/databases/$(database)/documents/babies/$(babyId)).data.members;
    }

    function canWrite(babyId) {
      let role = getRole(babyId);
      return role == 'owner' || role == 'admin' || role == 'parent';
    }

    function isOwnerOrAdmin(babyId) {
      let role = getRole(babyId);
      return role == 'owner' || role == 'admin';
    }

    // ── Babies ───────────────────────────────────────────────────────────────

    match /babies/{babyId} {
      allow read:   if isMember(babyId);
      allow create: if isSignedIn() &&
                       request.resource.data.members[request.auth.uid] == 'owner';
      allow update: if isOwnerOrAdmin(babyId);
      allow delete: if isSignedIn() && getRole(babyId) == 'owner';

      // Events
      match /events/{eventId} {
        allow read:             if isMember(babyId);
        allow create, update:   if canWrite(babyId);
        allow delete:           if canWrite(babyId);
      }

      // Weight logs
      match /weightLogs/{logId} {
        allow read:             if isMember(babyId);
        allow create, update, delete: if canWrite(babyId);
      }

      // Milestones
      match /milestones/{milestoneId} {
        allow read:             if isMember(babyId);
        allow create, update, delete: if canWrite(babyId);
      }

      // Vaccines
      match /vaccines/{vaccineId} {
        allow read:                   if isMember(babyId);
        allow create, update, delete: if canWrite(babyId);
      }
    }

    // ── Users ────────────────────────────────────────────────────────────────

    match /users/{userId} {
      allow read:  if isSignedIn();
      allow write: if request.auth.uid == userId;
    }

    // ── Invites ──────────────────────────────────────────────────────────────

    match /invites/{inviteId} {
      allow read:   if isSignedIn() &&
                       (resource.data.fromUid == request.auth.uid ||
                        resource.data.toEmail == request.auth.token.email);
      allow create: if isSignedIn() &&
                       request.resource.data.fromUid == request.auth.uid;
      allow update: if isSignedIn() &&
                       (resource.data.fromUid == request.auth.uid ||
                        resource.data.toEmail == request.auth.token.email);
      allow delete: if isSignedIn() &&
                       resource.data.fromUid == request.auth.uid;
    }

  }
}
